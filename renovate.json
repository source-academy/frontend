{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":label(dependencies)"],
  "packageRules": [
    // Non-dev dependencies are updated individually
    {
      "rangeStrategy": "update-lockfile",
      "matchPackageNames": ["*"],
      "minimumReleaseAge": "5 days"
    },
    {
      "matchPackageNames": ["/^@blueprintjs.*/"],
      "groupName": "blueprintjs"
    },
    // Group all non-major dev dependencies together
    {
      "groupName": "all dev dependencies (non-major)",
      "groupSlug": "all-dev-minor-patch",
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["minor", "patch"]
    }
  ],
  "enabledManagers": ["npm"]
}
